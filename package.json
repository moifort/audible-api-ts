{
  "name": "audible-api-ts",
  "version": "0.1.0",
  "description": "A fully typed TypeScript client for the Audible API — authentication, library, and wishlist",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target node --format esm --splitting",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "test:int": "cd src && bun test *.int.test.ts",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "audible",
    "audiobook",
    "amazon",
    "api",
    "typescript",
    "library",
    "wishlist",
    "pkce",
    "oauth"
  ],
  "author": "Thibaut",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moifort/audible-api-ts.git"
  },
  "bugs": {
    "url": "https://github.com/moifort/audible-api-ts/issues"
  },
  "homepage": "https://moifort.github.io/audible-api-ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "lodash-es": "^4.17.23",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.0",
    "@types/lodash-es": "^4.17.12",
    "typescript": "^5.7.0"
  }
}
